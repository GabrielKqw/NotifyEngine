generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TriggerType {
  WEBHOOK
  CRON
  RELATIVE_DATE
  REMINDER_SEQUENCE
  ICS_EVENT
  MANUAL
}

enum ConditionType {
  PAYLOAD_MATCH
  DATE_WINDOW
  GROUP_FILTER
  CUSTOM_JSON_RULE
}

enum ActionType {
  EMAIL_SMTP
  INTERNAL_GROUP_DISPATCH
  OUTBOUND_WEBHOOK
  INTERNAL_LOG
}

enum ExecutionStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
  CANCELED
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model Workspace {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  users       User[]
  groups      Group[]
  templates   Template[]
  automations Automation[]
  executions  Execution[]
  logs        Log[]
}

model User {
  id           String        @id @default(cuid())
  workspaceId  String
  email        String
  name         String
  passwordHash String?
  role         UserRole      @default(MEMBER)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  groupMembers GroupMember[]

  @@unique([workspaceId, email])
  @@index([workspaceId, role])
}

model Group {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     GroupMember[]

  @@unique([workspaceId, name])
}

model GroupMember {
  groupId   String
  userId    String
  createdAt DateTime @default(now())
  createdBy String?
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
}

model Template {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  subject     String
  bodyHtml    String
  bodyText    String?
  variables   Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automations Automation[]

  @@unique([workspaceId, name])
}

model Automation {
  id          String           @id @default(cuid())
  workspaceId String
  templateId  String?
  name        String
  description String?
  status      AutomationStatus @default(DRAFT)
  isActive    Boolean          @default(false)
  version     Int              @default(1)
  createdBy   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template    Template?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  triggers    Trigger[]
  conditions  Condition[]
  actions     Action[]
  executions  Execution[]

  @@unique([workspaceId, name])
  @@index([workspaceId, isActive])
  @@index([workspaceId, status])
}

model Trigger {
  id           String      @id @default(cuid())
  automationId String
  type         TriggerType
  config       Json
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  automation   Automation  @relation(fields: [automationId], references: [id], onDelete: Cascade)
  executions   Execution[]

  @@index([automationId, isActive])
  @@index([type])
}

model Condition {
  id           String        @id @default(cuid())
  automationId String
  type         ConditionType
  order        Int           @default(0)
  config       Json
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  automation   Automation    @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, order])
}

model Action {
  id           String                   @id @default(cuid())
  automationId String
  type         ActionType
  order        Int                      @default(0)
  config       Json
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  deletedAt    DateTime?
  automation   Automation               @relation(fields: [automationId], references: [id], onDelete: Cascade)
  attempts     ExecutionActionAttempt[]

  @@index([automationId, order])
  @@index([type])
}

model Execution {
  id             String                   @id @default(cuid())
  workspaceId    String
  automationId   String
  triggerId      String?
  sourceEventId  String?
  idempotencyKey String
  status         ExecutionStatus          @default(PENDING)
  context        Json?
  retryCount     Int                      @default(0)
  maxRetries     Int                      @default(3)
  nextRetryAt    DateTime?
  scheduledFor   DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  automation     Automation               @relation(fields: [automationId], references: [id], onDelete: Cascade)
  trigger        Trigger?                 @relation(fields: [triggerId], references: [id], onDelete: SetNull)
  attempts       ExecutionActionAttempt[]
  logs           Log[]

  @@unique([workspaceId, idempotencyKey])
  @@index([workspaceId, createdAt])
  @@index([automationId, createdAt])
  @@index([status, nextRetryAt])
}

model ExecutionActionAttempt {
  id              String          @id @default(cuid())
  executionId     String
  actionId        String
  idempotencyKey  String          @unique
  status          ExecutionStatus @default(PENDING)
  attemptNumber   Int             @default(1)
  startedAt       DateTime?
  finishedAt      DateTime?
  errorCode       String?
  errorMessage    String?
  responsePayload Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  execution       Execution       @relation(fields: [executionId], references: [id], onDelete: Cascade)
  action          Action          @relation(fields: [actionId], references: [id], onDelete: Cascade)
  logs            Log[]

  @@index([executionId, actionId, attemptNumber])
  @@index([status, createdAt])
}

model Log {
  id                       String                  @id @default(cuid())
  workspaceId              String
  executionId              String?
  executionActionAttemptId String?
  level                    LogLevel                @default(INFO)
  message                  String
  errorCode                String?
  stack                    String?
  data                     Json?
  createdAt                DateTime                @default(now())
  workspace                Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  execution                Execution?              @relation(fields: [executionId], references: [id], onDelete: SetNull)
  executionActionAttempt   ExecutionActionAttempt? @relation(fields: [executionActionAttemptId], references: [id], onDelete: SetNull)

  @@index([executionId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([level, createdAt])
}
